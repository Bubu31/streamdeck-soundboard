    "streamdeck",
    "soundboard",
    "audio"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "@elgato/utils": "^0.4.1",
    "chokidar": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
