{
  "name": "com.music-assistant.soundboard",
  "version": "1.0.0",
  "description": "Dynamic soundboard plugin for Stream Deck",
  "main": "dist/plugin.js",
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r dist/* com.music-assistant.soundboard.sdPlugin/",
    "watch": "tsc -w",
